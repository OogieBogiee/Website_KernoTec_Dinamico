# KERNOTEC - Git Ignore

# Variables de entorno 
.env
.env.local
.env.*.local

# Frontend Específicos
*.zip
*.rar
*.blend1
frontend/extra/
frontend/src/node_modules/
frontend/src/public/tween/
frontend/src/public/threejs/
frontend/src/public/ease/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Composer (PHP)
vendor/
composer.lock

# Docker
docker-compose.override.yml

# Strapi
backend/.tmp/
backend/build/
backend/.cache/
backend/dist/
backend/exports/
backend/.strapi-updater.json
backend/public/uploads/*
!backend/public/uploads/.gitkeep

# Base de datos local
*.sql
*.sqlite
*.sqlite3
.DS_Store

# Cache y logs
src/public/api/cache/*
!src/public/api/cache/.gitkeep
src/public/botman/bot/cache/*
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema operativo
Thumbs.db
.DS_Store
